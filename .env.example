# Database Configuration
DB_USER=fynza_user
DB_PASSWORD=your_secure_password_here
DB_NAME=fynza_ecommerce

# Redis Configuration
REDIS_PASSWORD=redis_password

# JWT Configuration (Generate a secure 256-bit key for production)
JWT_SECRET=your-256-bit-secret-key-here-change-in-production-minimum-32-chars

# CORS Configuration (comma-separated list of allowed origins)
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Spring Profile (dev, prod)
SPRING_PROFILE=prod

# Node Environment (development, production)
NODE_ENV=production

# Grafana Password
GRAFANA_PASSWORD=admin

# PayPal Configuration (Get from PayPal Developer Dashboard)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
