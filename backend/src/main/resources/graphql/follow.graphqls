# Follow GraphQL Schema
# Store following functionality

type StoreFollow {
    id: ID!
    user: User!
    seller: User!
    isActive: Boolean!
    createdAt: DateTime!
}

type FollowStats {
    followerCount: Int!
    followingCount: Int!
    isFollowing: Boolean!
}

input FollowInput {
    sellerId: ID!
}

extend type Query {
    # Security: AUTHENTICATED
    myFollowing(pagination: PageInput): StoreFollowConnection!
    
    # Security: PUBLIC - Check if following a store
    isFollowing(sellerId: ID!): Boolean!
    
    # Security: AUTHENTICATED
    followStats(sellerId: ID!): FollowStats!
    
    # Security: PUBLIC - Get store followers
    storeFollowers(sellerId: ID!, pagination: PageInput): UserConnection!
}

type StoreFollowConnection {
    content: [StoreFollow!]!
    pageInfo: PageInfo!
}

type UserConnection {
    content: [User!]!
    pageInfo: PageInfo!
}

extend type Mutation {
    # Security: AUTHENTICATED
    followStore(input: FollowInput!): StoreFollow!
    
    # Security: AUTHENTICATED
    unfollowStore(sellerId: ID!): Boolean!
}