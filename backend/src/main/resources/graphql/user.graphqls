enum Role {
    USER
    ADMIN
    SELLER
    CUSTOMER
    STAFF
}

"""
Security: No authentication required - Publicly accessible
"""
type User {
    id: ID!
    email: String!
    username: String!
    firstName: String!
    lastName: String!
    fullName: String!
    phoneNumber: String
    profileImageUrl: String
    role: Role!
    isActive: Boolean!
    emailVerified: Boolean!
    createdAt: DateTime!
    updatedAt: DateTime!
}

"""
Security: Requires AUTHENTICATION
"""
type UserPage {
    content: [User!]!
    pageInfo: PageInfo!
}

"""
Security: Requires ADMIN role
"""
type AdminDashboard {
    totalUsers: Long!
    totalProducts: Long!
    totalOrders: Long!
    totalRevenue: BigDecimal!
    pendingOrders: Long!
    activeUsers: Long!
    lowStockProducts: Long!
}

input UserCreateInput {
    email: String!
    username: String!
    password: String!
    firstName: String!
    lastName: String!
    phoneNumber: String
    role: Role!
}

input UserUpdateInput {
    email: String
    username: String
    firstName: String
    lastName: String
    phoneNumber: String
}

input UserFilterInput {
    search: String
    role: Role
    active: Boolean
    emailVerified: Boolean
    createdAfter: DateTime
    createdBefore: DateTime
    phoneNumber: String
    name: String
}

# ==================== Address Types ====================

enum AddressType {
    SHIPPING
    BILLING
    BOTH
}

type Address {
    id: ID!
    label: String
    addressType: AddressType!
    streetAddress: String!
    city: String!
    state: String!
    postalCode: String!
    country: String!
    isDefault: Boolean!
    createdAt: DateTime!
    updatedAt: DateTime!
}

input AddressInput {
    label: String
    addressType: AddressType
    streetAddress: String!
    city: String!
    state: String!
    postalCode: String!
    country: String!
    isDefault: Boolean
}

# Security:
# - user(id): Public
# - users: ADMIN only
# - currentUser: AUTHENTICATED only
# - adminDashboard: ADMIN only
# - staffDashboard: ADMIN or STAFF
extend type Query {
    user(id: ID!): User
    users(pagination: PageInput, filter: UserFilterInput): UserPage!
    currentUser: User
    adminDashboard: AdminDashboard!
    staffDashboard: AdminDashboard!
    
    # Address queries
    myAddresses: [Address!]!
}

extend type Mutation {
    createUser(input: UserCreateInput!): User!
    updateUser(id: ID!, input: UserUpdateInput!): User!
    deleteUser(id: ID!): Boolean!
    lockAccount(userId: ID!): Boolean!
    unlockAccount(userId: ID!): Boolean!
    
    # Address mutations
    addAddress(input: AddressInput!): Address!
    updateAddress(id: ID!, input: AddressInput!): Address!
    deleteAddress(id: ID!): Boolean!
}
