# Notification GraphQL Schema

enum NotificationType {
    ORDER_STATUS
    PAYMENT
    SHIPPING
    PROMOTION
    REVIEW
    WISHLIST
    SYSTEM
}

enum NotificationChannel {
    IN_APP
    EMAIL
    SMS
    PUSH
}

type Notification {
    id: ID!
    type: String!
    title: String!
    message: String!
    isRead: Boolean!
    relatedEntityId: ID
    createdAt: DateTime!
}

extend type Query {
    # Security: AUTHENTICATED - User's own notifications
    myNotifications: [Notification!]!
}

extend type Mutation {
    # Security: AUTHENTICATED
    markNotificationAsRead(id: ID!): Notification!
    markAllNotificationsAsRead: Boolean!
}
